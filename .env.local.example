# ===========================================
# Local Environment Overrides
# ===========================================
# Copy this file to .env.local and fill in your values
# This file is .gitignored and will not be committed

# ===========================================
# Supabase Remote Database Connection
# ===========================================
# Get these values from: Supabase Dashboard > Settings > Database

# Connection password (from Connection string section)
# IMPORTANT: This is the password for direct database access
# Do NOT confuse with your Supabase account password
SUPABASE_DB_PASSWORD=your_supabase_database_password_here

# Alternative direct connection URL (optional, will be constructed if not set)
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.vclwajxnqslrwkwkhwrw.supabase.co:5432/postgres?sslmode=require

# ===========================================
# Supabase Service Role Key
# ===========================================
# From: Supabase Dashboard > Settings > API
# Used for server-side operations requiring elevated privileges
# Keep this secret! Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================================
# Override Database Provider
# ===========================================
# Uncomment to force using Supabase even in development
# USE_REMOTE=true
