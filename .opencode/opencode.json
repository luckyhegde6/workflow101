{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": [
    "AGENTS.md",
    "skills/tdd-workflow/SKILL.md",
    "skills/security-review/SKILL.md",
    "skills/coding-standards/SKILL.md",
    "skills/workflow-patterns/SKILL.md",
    "skills/dbos-integration/SKILL.md",
    "skills/backend-patterns/SKILL.md",
    "skills/frontend-patterns/SKILL.md",
    "skills/api-design/SKILL.md",
    "skills/eval-harness/SKILL.md",
    "skills/verification-loop/SKILL.md",
    "skills/e2e-testing/SKILL.md"
  ],
  "plugin": [
    "./plugins"
  ],
  "agent": {
    "build": {
      "description": "Primary coding agent for workflow101 development",
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true
      }
    },
    "planner": {
      "description": "Expert planning specialist for workflow features and DBOS integration",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/agents/planner.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "tdd-guide": {
      "description": "Test-Driven Development specialist for DBOS workflows and Next.js",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/agents/tdd-guide.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "code-reviewer": {
      "description": "Code review specialist for workflow patterns and DBOS SDK",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/agents/code-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "security-reviewer": {
      "description": "Security specialist for workflow inputs and Vercel deployment",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/agents/security-reviewer.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "build-error-resolver": {
      "description": "Build and TypeScript error resolution for Next.js and DBOS",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/agents/build-error-resolver.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "e2e-runner": {
      "description": "E2E testing specialist for workflow pages using Playwright",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/agents/e2e-runner.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "workflow-expert": {
      "description": "DBOS workflow patterns specialist for useworkflow.dev patterns",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/agents/workflow-expert.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "command": {
    "plan": {
      "description": "Create implementation plan for workflow features",
      "template": "{file:.opencode/commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "tdd": {
      "description": "TDD workflow for DBOS workflows and Next.js components",
      "template": "{file:.opencode/commands/tdd.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "code-review": {
      "description": "Review workflow code and DBOS patterns",
      "template": "{file:.opencode/commands/code-review.md}\n\n$ARGUMENTS",
      "agent": "code-reviewer",
      "subtask": true
    },
    "security": {
      "description": "Security review for workflow inputs and API endpoints",
      "template": "{file:.opencode/commands/security.md}\n\n$ARGUMENTS",
      "agent": "security-reviewer",
      "subtask": true
    },
    "build-fix": {
      "description": "Fix Next.js and TypeScript build errors",
      "template": "{file:.opencode/commands/build-fix.md}\n\n$ARGUMENTS",
      "agent": "build-error-resolver",
      "subtask": true
    },
    "e2e": {
      "description": "Run E2E tests for workflow pages",
      "template": "{file:.opencode/commands/e2e.md}\n\n$ARGUMENTS",
      "agent": "e2e-runner",
      "subtask": true
    }
  },
  "permission": {
    "mcp_*": "ask"
  }
}
