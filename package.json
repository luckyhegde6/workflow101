{
  "name": "workflow101",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "local": "npm run db:up && npm run dbos:init && npm run dev",
    "dev:db": "npm run db:up",
    "dev:server": "npm run dev",
    "db:up": "bash scripts/dev-db-up.sh",
    "db:down": "bash scripts/dev-db-down.sh",
    "db:psql": "docker compose exec -T postgres psql -U postgres -d workflow101",
    "db:logs": "docker compose logs -f postgres",
    "dbos:init": "node scripts/dbos-init.cjs",
    "docker:terminate:win": "powershell -ExecutionPolicy Bypass -File scripts/docker-terminate.ps1",
    "docker:terminate": "node scripts/docker-terminate-cross.cjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:api": "vitest run tests/api",
    "test:unit": "vitest run tests/unit",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e",
    "db:config": "node scripts/test-db-config.js",
    "db:test-supabase": "node scripts/test-supabase-connection.js",
    "security:check": "node scripts/pre-commit-security.js",
    "security:install-hooks": "npx husky add .husky/pre-commit \"npm run security:check\""
  },
  "dependencies": {
    "@dbos-inc/dbos-sdk": "^4.11.11",
    "@sentry/nextjs": "^10.46.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/functions": "^3.4.3",
    "@vercel/otel": "^2.1.1",
    "@vercel/queue": "^0.1.4",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swagger-ui-react": "^5.32.1",
    "workflow": "^4.2.0-beta.72"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "undici": "^7.24.6",
    "vitest": "^2.1.9",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  }
}
